instructions/claude/trigger_antigravity.md
instructions/chat/trigger_chat.md
instructions/chat/command_glossary_chat.md
instructions/model_agnostic/trigger_generic.md
instructions/model_agnostic/PORTABLE_DEPLOYMENT.md
instructions/model_agnostic/kernel_profiles.md
instructions/model_agnostic/.gitignore.host
instructions/model_agnostic/instructions_dummies.md
agent/agent_outputs/runtime/
# Optional framework metadata files at host root
AGENTS.md
agent.md

.venv/
__pycache__/
**/__pycache__/
**/*pycache*/
.DS_Store
*.log
logs/
build/
dist/
spec/
test/
*pycache/

# Tinker v2 framework (portable - not part of host project)

.githooks/
.gitattributes
